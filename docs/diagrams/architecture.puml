@startuml architecture
!theme plain
skinparam backgroundColor white
skinparam componentStyle rectangle
skinparam dpi 130
skinparam packageBackgroundColor #fafafa
skinparam componentBackgroundColor #ffffff
skinparam ArrowColor #555555
skinparam defaultFontName Helvetica
skinparam defaultFontSize 15
skinparam packageFontSize 17
skinparam packageFontStyle bold
skinparam noteFontSize 13
skinparam nodesep 70
skinparam ranksep 90
skinparam padding 8

title AgentAid — System Architecture

' High-level overview. Per-layer detail diagrams live alongside this one:
'   • docs/diagrams/agent-sdk-layer.png
'   • docs/diagrams/server-layer.png
'   • docs/diagrams/frontend-layer.png

left to right direction

' ───────────────────────────────────────────────────────────────────
' Agent + SDK Layer
' ───────────────────────────────────────────────────────────────────
package "Agent + SDK Layer" #f4f8ff {
  [Reference Agent\n\n• Pydantic AI\n• planner + worker\n• multi-modal vision\n• mock arXiv default,\n  real arXiv feature-flagged] as Agent
  [Bare Anthropic\nSDK Example\n\nframework-agnostic\nproof point] as Bare
  component "agentaid SDK\n(Python + TypeScript)\n\nOTel/GenAI emitter" as Sdk

  Agent --> Sdk : emit\notel/genai spans
  Bare  --> Sdk : manual\notel/genai
}

' ───────────────────────────────────────────────────────────────────
' Server Layer  (FastAPI + SQLModel async)
' ───────────────────────────────────────────────────────────────────
package "Server Layer  (FastAPI + SQLModel async)" #fff5e8 {
  [Ingest\n/ingest] as Ingest
  database "SQLite" as DB
  [Eval Orchestrator\n(modes 1 + 3)] as EvalOrch
  [Regression Driver\n(mode 2)] as RegOrch
  [Drift Workers\nADWIN · MMD · PSI] as Drift
  [REST API\n/runs · /evals · /drift\n/datasets · /regressions\n/compare] as Api

  Ingest   --> DB : write spans + run
  Ingest   ..> EvalOrch : background tasks\nper terminated run
  EvalOrch --> DB : write\nEvalResult
  RegOrch  --> DB : write\nRegressionRun
  Drift    --> DB : poll evals + spans (5 s)\nwrite DriftStateRow
  Api      <-- DB
}

' ───────────────────────────────────────────────────────────────────
' Frontend  (per-route detail lives in frontend-layer.png)
' ───────────────────────────────────────────────────────────────────
package "Frontend Layer" #f3fff3 {
  [SPA\n\n• React 19 + Vite + TypeScript\n• TanStack Query (typed REST client)\n• Recharts (drift series, score deltas)\n• Routes: drift home, trace detail (Gantt),\n  run comparison, drift detail × 3,\n  eval results, datasets, run list] as Spa
}

' ───────────────────────────────────────────────────────────────────
' Cross-layer wiring
' ───────────────────────────────────────────────────────────────────
Sdk     --> Ingest : HTTP POST  /ingest\n{spans: [ … ]}
RegOrch --> Agent  : drive dataset rows\n(regression mode)
Spa     --> Api    : typed REST client\n(GET /runs · /evals\n /drift · /compare · …)

@enduml
